{
  "name": "inhouse-recorder",
  "version": "1.0.0",
  "description": "A collaborative local-first screen recorder for macOS and Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64",
    "dist:win": "electron-builder --win --x64"
  },
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.antigravity.inhouserecorder",
    "productName": "InhouseRecorder",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false
    },
    "directories": {
      "output": "dist"
    }
  }
}
